{
  "experiment": {
    "module": "continuous",
    "name": "continuous_smoke",
    "seed": 11,
    "run_dir": "runs",
    "artifact_dir": "artifacts/continuous"
  },
  "environment": {
    "big_radius": 1.0,
    "small_radius": 0.3,
    "collision_radius": 0.08,
    "max_steps": 500,
    "switch_interval": 160,
    "intruder_max_speed": 0.018,
    "interceptor_max_speed": 0.022,
    "world_radius": 1.5,
    "detour_safe_distance": 0.35
  },
  "ppo": {
    "total_timesteps": 2000,
    "n_steps": 128,
    "batch_size": 64,
    "learning_rate": 0.0003,
    "gamma": 0.99
  },
  "detector": {
    "method": "sam",
    "initial_policy": "direct",
    "threshold": 8.0,
    "decay": 0.05
  },
  "sam": {
    "enabled": true,
    "sample_steps": 300,
    "hidden_dim": 32,
    "dropout": 0.1,
    "epochs": 3,
    "batch_size": 64,
    "learning_rate": 0.001,
    "mc_passes": 8,
    "noise_variance": 0.0001,
    "online_learning_rate": 0.0003
  },
  "evaluation": {
    "episodes": 10,
    "deterministic": false
  }
}